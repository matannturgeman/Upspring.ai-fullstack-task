    "express": "5.2.1",
    "express-rate-limit": "8.3.2",
    "helmet": "8.1.0",
    "mongoose": "9.4.1",
    "morgan": "1.10.1",
    "node-fetch": "3.3.2"
  },
  "devDependencies": {
    "supertest": "7.2.2",
    "vite-node": "6.0.0",
    "vitest": "4.1.4"
