{
  "name": "upspring-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite-node --watch server.ts",
    "start": "node server.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npm run lint",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.88.0",
    "apify-client": "2.23.0",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.3.2",
    "helmet": "8.1.0",
    "http-status-codes": "2.3.0",
    "mongoose": "9.4.1",
    "morgan": "1.10.1",
    "node-fetch": "3.3.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/morgan": "1.9.10",
    "@types/node": "25.6.0",
    "@types/supertest": "7.2.0",
    "prettier": "^3.8.3",
    "supertest": "7.2.2",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2",
    "vite-node": "6.0.0",
    "vitest": "4.1.4"
  }
}
