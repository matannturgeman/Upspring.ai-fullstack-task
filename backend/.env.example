MONGODB_URI=mongodb://localhost:27017/upspring
ANTHROPIC_API_KEY=XX
PERPLEXITY_API_KEY=XX
FRONTEND_URL=http://localhost:5173
PORT=4000

# Mock flags (independent)
MOCK_LLM=true
MOCK_SCRAPER=true

# Scraper priority — tried left to right, falls back on failure
SCRAPER_PRIORITY=apify,scrapingbee,rapidapi

# Apify (https://apify.com)
APIFY_API_TOKEN=XX

# ScrapingBee (https://www.scrapingbee.com)
SCRAPINGBEE_API_KEY=XX

# RapidAPI (https://rapidapi.com/search/facebook+ads+library)
RAPIDAPI_KEY=XX
RAPIDAPI_HOST=facebook-ads-library.p.rapidapi.com
